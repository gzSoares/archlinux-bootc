[Unit]
Description=First Boot Post-Install Setup (archlinux-bootc)
After=network-online.target flatpak-system-helper.service
Wants=network-online.target
ConditionPathExists=/usr/bin/post-install.sh

[Service]
Type=oneshot
ExecStart=/usr/bin/post-install.sh
RemainAfterExit=yes
# High timeout: dkms compiles the NVIDIA module from source on first boot
TimeoutStartSec=600
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
